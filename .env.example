# ─────────────────────────────────────────────────────────────
# MetalMotor-AI environment variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` or real secrets.
# ─────────────────────────────────────────────────────────────

# Public site URL (used for SEO canonical, sitemap, OpenGraph).
NEXT_PUBLIC_SITE_URL="https://metalmotor.cl"

# Public WhatsApp number in international format, digits only.
# Example for Chile: 56912345678
NEXT_PUBLIC_WHATSAPP_NUMBER="56900000000"

# Public contact email shown on the site.
NEXT_PUBLIC_CONTACT_EMAIL="contacto@metalmotor.cl"

# ── Supabase (server-side lead persistence) ──
# Project URL from Supabase dashboard → Project Settings → API.
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"

# Service-role key (server only — bypasses RLS). NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
