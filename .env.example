# ─────────────────────────────────────────────────────────────
# MetalMotor-AI environment variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` or real secrets.
# ─────────────────────────────────────────────────────────────

# Public site URL — production domain (used for SEO canonical, sitemap, OpenGraph, JSON-LD).
# Must match the live domain exactly to avoid SEO issues.
NEXT_PUBLIC_SITE_URL="https://www.metalmotor.cl"

# Public WhatsApp number in international format, digits only.
# Example for Chile: 56912345678
NEXT_PUBLIC_WHATSAPP_NUMBER="56900000000"

# Public contact email shown on the site (general). Corporate Zoho address.
NEXT_PUBLIC_CONTACT_EMAIL="contacto@metalmotor.cl"

# Google Analytics 4 measurement ID. If empty, no GA script loads and no events
# are sent (the site works normally). Format: G-XXXXXXXXXX.
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# ── Supabase (server-side lead persistence) ──
# Project URL from Supabase dashboard → Project Settings → API.
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"

# Service-role key (server only — bypasses RLS). NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── Email notifications (Resend) ──
# When RESEND_API_KEY is absent, the email channel is simply skipped and the
# lead is still captured (graceful degradation). Set it to enable staff alerts.
RESEND_API_KEY="re_your_api_key"

# Destino de las alertas de cotización/RFQ (Zoho). Default: cotizaciones@metalmotor.cl
# (campañas comerciales: usar ventas@metalmotor.cl; contacto general: contacto@metalmotor.cl)
NOTIFICATIONS_TO_EMAIL="cotizaciones@metalmotor.cl"

# Remitente verificado. Hasta verificar el dominio metalmotor.cl en Resend (SPF/DKIM),
# usar el sender de onboarding de Resend (default). Tras verificar DNS, cambiar a
# e.g. contacto@metalmotor.cl — sin cambios de código.
NOTIFICATIONS_FROM_EMAIL="onboarding@resend.dev"
